{% liquid
  assign section_id = 'gift-grid-' | append: section.id
%}

<section id="{{ section_id }}" class="gift-grid-section">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="gift-grid-section__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="gift-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product != blank %}
          <article
            class="gift-grid__item"
            {{ block.shopify_attributes }}
            data-product-json="{{ product | json | escape }}"
          >
            <div class="gift-grid__image-wrap">
              {% if product.featured_image != blank %}
                {{
                  product.featured_image
                  | image_url: width: 900
                  | image_tag:
                    class: 'gift-grid__image',
                    loading: 'lazy',
                    widths: '320, 450, 700, 900'
                }}
              {% endif %}

              <button
                type="button"
                class="gift-grid__trigger"
                aria-label="Open product details for {{ product.title | escape }}"
              >
                +
              </button>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="gift-modal" hidden>
    <div class="gift-modal__overlay" data-close-modal></div>

    <div class="gift-modal__dialog" role="dialog" aria-modal="true" aria-label="Product details">
      <button type="button" class="gift-modal__close" data-close-modal>×</button>

      <div class="gift-modal__content">
        <div class="gift-modal__media">
          <img class="gift-modal__image" src="" alt="">
        </div>

        <div class="gift-modal__info">
          <h3 class="gift-modal__title"></h3>
          <div class="gift-modal__price"></div>
          <div class="gift-modal__description"></div>

          <div class="gift-modal__options"></div>

          <button type="button" class="gift-modal__add">Add to cart →</button>
          <div class="gift-modal__status" aria-live="polite"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #{{ section_id }} .page-width {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  #{{ section_id }} .gift-grid-section__heading {
    margin: 56px 0 24px;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 400;
    line-height: 1.1;
  }

  #{{ section_id }} .gift-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  #{{ section_id }} .gift-grid__item {
    position: relative;
  }

  #{{ section_id }} .gift-grid__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 0.88 / 1;
    background: #f5f5f5;
  }

  #{{ section_id }} .gift-grid__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #{{ section_id }} .gift-grid__trigger {
    position: absolute;
    right: 12px;
    top: 12px;
    width: 30px;
    height: 30px;
    border: 0;
    border-radius: 50%;
    background: rgba(255,255,255,.92);
    color: #000;
    cursor: pointer;
    font-size: 22px;
    line-height: 1;
    display: grid;
    place-items: center;
  }

  #{{ section_id }} .gift-modal[hidden] {
    display: none;
  }

  #{{ section_id }} .gift-modal {
    position: fixed;
    inset: 0;
    z-index: 999;
  }

  #{{ section_id }} .gift-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.28);
  }

  #{{ section_id }} .gift-modal__dialog {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(92vw, 460px);
    background: #fff;
    padding: 18px;
    box-shadow: 0 18px 50px rgba(0,0,0,.18);
  }

  #{{ section_id }} .gift-modal__close {
    position: absolute;
    top: 8px;
    right: 10px;
    border: 0;
    background: transparent;
    font-size: 24px;
    cursor: pointer;
  }

  #{{ section_id }} .gift-modal__content {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 14px;
  }

  #{{ section_id }} .gift-modal__image {
    width: 100%;
    height: auto;
    display: block;
  }

  #{{ section_id }} .gift-modal__title {
    margin: 0 0 8px;
    font-size: 20px;
    line-height: 1.2;
  }

  #{{ section_id }} .gift-modal__price {
    margin-bottom: 10px;
    font-size: 17px;
    font-weight: 600;
  }

  #{{ section_id }} .gift-modal__description {
    margin-bottom: 14px;
    font-size: 13px;
    line-height: 1.5;
  }

  #{{ section_id }} .gift-modal__option-group {
    margin-bottom: 14px;
  }

  #{{ section_id }} .gift-modal__option-label {
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  #{{ section_id }} .gift-modal__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  #{{ section_id }} .gift-modal__swatch,
  #{{ section_id }} .gift-modal__select {
    border: 1px solid #cfcfcf;
    background: #fff;
    min-height: 38px;
  }

  #{{ section_id }} .gift-modal__swatch {
    padding: 0 14px;
    cursor: pointer;
  }

  #{{ section_id }} .gift-modal__swatch.is-active {
    border-color: #000;
  }

  #{{ section_id }} .gift-modal__select {
    width: 100%;
    padding: 0 12px;
  }

  #{{ section_id }} .gift-modal__add {
    width: 100%;
    min-height: 46px;
    border: 0;
    background: #000;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: .05em;
    font-weight: 700;
    cursor: pointer;
  }

  #{{ section_id }} .gift-modal__status {
    margin-top: 10px;
    font-size: 12px;
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} .gift-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #{{ section_id }} .gift-modal__content {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .gift-modal__media {
      max-width: 140px;
    }
  }
</style>

<script>
  (() => {
    const root = document.getElementById('{{ section_id }}');
    if (!root) return;

    const modal = root.querySelector('.gift-modal');
    const modalImage = root.querySelector('.gift-modal__image');
    const modalTitle = root.querySelector('.gift-modal__title');
    const modalPrice = root.querySelector('.gift-modal__price');
    const modalDescription = root.querySelector('.gift-modal__description');
    const modalOptions = root.querySelector('.gift-modal__options');
    const addButton = root.querySelector('.gift-modal__add');
    const statusBox = root.querySelector('.gift-modal__status');

    let activeProduct = null;
    let selectedOptions = {};

    const moneyFormat = (cents) => {
      return new Intl.NumberFormat('en-CA', {
        style: 'currency',
        currency: '{{ cart.currency.iso_code | default: shop.currency }}'
      }).format((cents || 0) / 100);
    };

    const getVariantFromSelections = (product) => {
      if (!product || !product.variants) return null;

      return product.variants.find((variant) => {
        return product.options.every((optionName, index) => {
          const key = `option${index + 1}`;
          return (selectedOptions[optionName] || '') === (variant[key] || '');
        });
      }) || null;
    };

    const renderOptions = (product) => {
      modalOptions.innerHTML = '';
      selectedOptions = {};

      product.options.forEach((optionName, optionIndex) => {
        const values = [...new Set(product.variants.map(v => v[`option${optionIndex + 1}`]).filter(Boolean))];
        selectedOptions[optionName] = values[0] || '';

        const group = document.createElement('div');
        group.className = 'gift-modal__option-group';

        const label = document.createElement('div');
        label.className = 'gift-modal__option-label';
        label.textContent = optionName;
        group.appendChild(label);

        if (optionName.toLowerCase() === 'size') {
          const select = document.createElement('select');
          select.className = 'gift-modal__select';

          values.forEach((value) => {
            const option = document.createElement('option');
            option.value = value;
            option.textContent = value;
            select.appendChild(option);
          });

          select.addEventListener('change', () => {
            selectedOptions[optionName] = select.value;
            syncVariantUI();
          });

          group.appendChild(select);
        } else {
          const swatches = document.createElement('div');
          swatches.className = 'gift-modal__swatches';

          values.forEach((value, index) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'gift-modal__swatch' + (index === 0 ? ' is-active' : '');
            button.textContent = value;

            button.addEventListener('click', () => {
              selectedOptions[optionName] = value;
              swatches.querySelectorAll('.gift-modal__swatch').forEach(btn => btn.classList.remove('is-active'));
              button.classList.add('is-active');
              syncVariantUI();
            });

            swatches.appendChild(button);
          });

          group.appendChild(swatches);
        }

        modalOptions.appendChild(group);
      });
    };

    const syncVariantUI = () => {
      const variant = getVariantFromSelections(activeProduct);
      if (!variant) {
        addButton.disabled = true;
        modalPrice.textContent = 'Unavailable';
        return;
      }

      addButton.disabled = !variant.available;
      modalPrice.textContent = moneyFormat(variant.price);
    };

    const openModal = (product) => {
      activeProduct = product;

      modalImage.src = product.featured_image;
      modalImage.alt = product.title || '';
      modalTitle.textContent = product.title || '';
      modalDescription.innerHTML = product.description || '';

      renderOptions(product);
      syncVariantUI();

      statusBox.textContent = '';
      modal.hidden = false;
      document.body.classList.add('overflow-hidden');
    };

    const closeModal = () => {
      modal.hidden = true;
      document.body.classList.remove('overflow-hidden');
    };

    const addItemsToCart = async (items) => {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items })
      });

      if (!response.ok) {
        throw new Error('Failed to add items to cart.');
      }

      return response.json();
    };

    const getBonusVariantId = async () => {
      const handle = '{{ section.settings.soft_winter_jacket.handle }}';
      if (!handle) return null;

      const response = await fetch(`/products/${handle}.js`);
      if (!response.ok) return null;

      const jacket = await response.json();
      return jacket?.variants?.[0]?.id || null;
    };

    root.querySelectorAll('.gift-grid__item').forEach((item) => {
      const trigger = item.querySelector('.gift-grid__trigger');
      if (!trigger) return;

      trigger.addEventListener('click', () => {
        const raw = item.getAttribute('data-product-json');
        if (!raw) return;
        openModal(JSON.parse(raw));
      });
    });

    root.querySelectorAll('[data-close-modal]').forEach((el) => {
      el.addEventListener('click', closeModal);
    });

    addButton.addEventListener('click', async () => {
      if (!activeProduct) return;

      const selectedVariant = getVariantFromSelections(activeProduct);
      if (!selectedVariant) {
        statusBox.textContent = 'Please select a valid variant.';
        return;
      }

      try {
        const items = [{ id: selectedVariant.id, quantity: 1 }];

        const color = selectedVariant.option1 || '';
        const size = selectedVariant.option2 || '';

        if (color.toLowerCase() === 'black' && size.toLowerCase() === 'medium') {
          const bonusId = await getBonusVariantId();
          if (bonusId) {
            items.push({ id: bonusId, quantity: 1 });
          }
        }

        await addItemsToCart(items);
        statusBox.textContent = 'Added to cart.';
      } catch (error) {
        statusBox.textContent = 'Could not add to cart. Please try again.';
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !modal.hidden) {
        closeModal();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Custom Product Grid Popup",
  "tag": "section",
  "class": "section section-custom-product-grid-popup",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tisso vision in the wild" },
    { "type": "product", "id": "soft_winter_jacket", "label": "Soft Winter Jacket product" }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Product Grid Popup",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}