{% liquid
  assign section_id = 'gift-banner-' | append: section.id
%}

<section id="{{ section_id }}" class="gift-banner">
  <div class="gift-banner__topbar page-width">
    <div class="gift-banner__brand">{{ section.settings.brand_text }}</div>
    <div class="gift-banner__eyebrow">{{ section.settings.top_message }}</div>
    <a class="gift-banner__choose-link" href="{{ section.settings.choose_gift_link }}">
      <span>{{ section.settings.choose_gift_text }}</span>
      <span class="gift-banner__arrow">→</span>
    </a>
  </div>

  <div class="gift-banner__hero page-width">
    <div class="gift-banner__content">
      <h1 class="gift-banner__heading">{{ section.settings.heading }}</h1>
      <div class="gift-banner__description">{{ section.settings.description }}</div>

      <a class="gift-banner__button" href="{{ section.settings.button_link }}">
        <span>{{ section.settings.button_text }}</span>
        <span class="gift-banner__arrow">→</span>
      </a>
    </div>

    <div class="gift-banner__image-wrap">
      {% if section.settings.hero_image != blank %}
        {{
          section.settings.hero_image
          | image_url: width: 2200
          | image_tag:
            class: 'gift-banner__image',
            loading: 'lazy',
            widths: '550, 750, 1100, 1500, 2200'
        }}
      {% endif %}
    </div>
  </div>

  <div class="gift-banner__footerbar page-width">
    <p>{{ section.settings.bottom_message }}</p>
  </div>
</section>

<style>
  #{{ section_id }} {
    background: {{ section.settings.section_bg }};
    color: #000;
    padding-top: 24px;
  }

  #{{ section_id }} .page-width {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  #{{ section_id }} .gift-banner__topbar,
  #{{ section_id }} .gift-banner__footerbar {
    background: {{ section.settings.bar_bg }};
    display: grid;
    grid-template-columns: 180px 1fr 170px;
    align-items: center;
    min-height: 52px;
  }

  #{{ section_id }} .gift-banner__brand {
    font-size: 24px;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  #{{ section_id }} .gift-banner__eyebrow,
  #{{ section_id }} .gift-banner__footerbar p {
    text-align: center;
    font-size: 13px;
    line-height: 1.4;
    margin: 0;
  }

  #{{ section_id }} .gift-banner__choose-link,
  #{{ section_id }} .gift-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    text-decoration: none;
    transition: transform .25s ease, box-shadow .25s ease, background-color .25s ease;
  }

  #{{ section_id }} .gift-banner__choose-link {
    justify-self: end;
    background: #efe84a;
    color: #000;
    min-height: 44px;
    padding: 0 18px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  #{{ section_id }} .gift-banner__button {
    background: #000;
    color: #fff;
    min-height: 50px;
    padding: 0 24px;
    width: fit-content;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
  }

  #{{ section_id }} .gift-banner__choose-link:hover,
  #{{ section_id }} .gift-banner__button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,.12);
  }

  #{{ section_id }} .gift-banner__arrow {
    display: inline-block;
    transition: transform .25s ease;
  }

  #{{ section_id }} .gift-banner__choose-link:hover .gift-banner__arrow,
  #{{ section_id }} .gift-banner__button:hover .gift-banner__arrow {
    transform: translateX(4px);
  }

  #{{ section_id }} .gift-banner__hero {
    display: grid;
    grid-template-columns: 440px 1fr;
    align-items: end;
    gap: 28px;
    position: relative;
    overflow: hidden;
    background: {{ section.settings.hero_bg }};
  }

  #{{ section_id }} .gift-banner__content {
    position: relative;
    z-index: 2;
    padding: 72px 0 72px;
  }

  #{{ section_id }} .gift-banner__heading {
    margin: 0 0 20px;
    font-size: clamp(42px, 6vw, 88px);
    line-height: 0.95;
    font-weight: 500;
    letter-spacing: -0.03em;
  }

  #{{ section_id }} .gift-banner__description {
    max-width: 360px;
    margin-bottom: 28px;
    font-size: 17px;
    line-height: 1.55;
  }

  #{{ section_id }} .gift-banner__image-wrap {
    min-height: 540px;
    display: flex;
    align-items: stretch;
    justify-content: flex-end;
  }

  #{{ section_id }} .gift-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 989px) {
    #{{ section_id }} .gift-banner__topbar {
      grid-template-columns: 1fr;
      gap: 10px;
      padding-top: 12px;
      padding-bottom: 12px;
    }

    #{{ section_id }} .gift-banner__brand,
    #{{ section_id }} .gift-banner__eyebrow,
    #{{ section_id }} .gift-banner__choose-link {
      justify-self: center;
      text-align: center;
    }

    #{{ section_id }} .gift-banner__hero {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .gift-banner__content {
      padding: 40px 0 24px;
    }

    #{{ section_id }} .gift-banner__image-wrap {
      min-height: 320px;
    }

    #{{ section_id }} .gift-banner__footerbar {
      grid-template-columns: 1fr;
      padding-top: 10px;
      padding-bottom: 10px;
    }
    #{{ section_id }} .gift-banner__footerbar p {
      margin: 0;
      white-space: nowrap;
      align-item: center;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Gift Banner",
  "tag": "section",
  "class": "section section-custom-gift-banner",
  "settings": [
    { "type": "text", "id": "brand_text", "label": "Brand text", "default": "TISSO VISION" },
    { "type": "text", "id": "top_message", "label": "Top message", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "choose_gift_text", "label": "Choose gift text", "default": "Choose gift" },
    { "type": "url", "id": "choose_gift_link", "label": "Choose gift link" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Gift Guide" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Discover joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "bottom_message", "label": "Bottom message", "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL" },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "bar_bg", "label": "Bar background", "default": "#f4f4f1" },
    { "type": "color", "id": "hero_bg", "label": "Hero background", "default": "#ffffff" }
  ],
  "presets": [
    { "name": "Custom Gift Banner" }
  ]
}
{% endschema %}